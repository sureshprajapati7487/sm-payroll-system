# Server Environment Variables
# Copy this to .env for local development:
#   cp server/.env.example server/.env
# In production (Render), set these via Dashboard > Environment Variables

PORT=3000
NODE_ENV=development

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# ⚠️  IMPORTANT: In production, replace these with RANDOM 64-char strings!
# Generate strong secrets:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Server will CRASH on startup if these are missing in production.
JWT_SECRET=sm-payroll-super-secret-jwt-key-2026
JWT_EXPIRES=15m
REFRESH_SECRET=sm-payroll-refresh-secret-key-2026-v2

# ── Frontend URL (used in CORS whitelist) ──────────────────────────────────────
# Production: set to your Vercel URL e.g. https://sm-payroll.vercel.app
FRONTEND_URL=http://localhost:5173
