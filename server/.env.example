# Server Environment Variables
# Copy this to .env for local development
# In production (Render), set these via Dashboard or render.yaml

PORT=3000
NODE_ENV=development

# JWT Secrets — change these to random strings in production!
JWT_SECRET=sm-payroll-super-secret-jwt-key-2026
JWT_EXPIRES=15m
REFRESH_SECRET=sm-payroll-refresh-secret-key-2026-v2

# Frontend URL (used in CORS whitelist)
# Production: set to your Vercel URL e.g. https://sm-payroll.vercel.app
FRONTEND_URL=http://localhost:5173
